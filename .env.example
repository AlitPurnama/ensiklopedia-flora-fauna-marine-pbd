# Postgres (matches docker-compose.yml)
DATABASE_URL=postgres://pbd:pbd@localhost:5432/ensiklopedia

# Single admin login. Plaintext here is fine — .env is the trust boundary.
ADMIN_EMAIL=admin@pbd.local
ADMIN_PASSWORD=changeme

# Any long random string. Signs the session cookie.
SESSION_SECRET=replace-with-a-long-random-string
